# ─────────────────────────────────────────────────────────────────
# Darklock Secure Notes — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Server (apps/server) ──────────────────────────────────────────

# JWT signing secret — REQUIRED in production (min 32 chars, random)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# HMAC key for anti-enumeration dummy salts — REQUIRED in production
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
DUMMY_SALT_KEY=

# Node environment (development | production)
NODE_ENV=development

# API server port (default: 3003)
PORT=3003

# SQLite database path (default: ./data/darklock-notes.db)
# DB_PATH=./data/darklock-notes.db

# ── Web app (apps/web) ────────────────────────────────────────────

# Dev-only auth bypass — NEVER set in production builds
# Only active when import.meta.env.DEV === true
# VITE_DEV_BYPASS=true

# ── Desktop app (apps/desktop) ────────────────────────────────────

# Same as web — dev bypass, dev builds only
# VITE_DEV_BYPASS=true
